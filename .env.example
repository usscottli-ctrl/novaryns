# Novaryns environment variables.
#
# 推荐用 docker compose 部署(见 docker-compose.yml)——数据库/存储/密钥都已配好,
# 打开站点走「首启配置向导」填 OpenAI API Key 即可,基本不需要手改本文件。
# 手动部署(npm run build && npm start)时,复制本文件为 `.env.local` 再填。

# --- Database (Postgres) ---
# 必填(生产)。用户/积分/作品/设置都存这里,schema 首次访问自动建。
# docker compose 已内置;手动部署可用任意 Postgres(自建 / Supabase / RDS / Neon)。
DATABASE_URL=

# --- Settings encryption ---
# 用于 AES-256-GCM 加密落库的 API Key 等敏感设置。设一个长随机串,设完永远别改。
SETTINGS_SECRET=

# --- AI image generation (OpenAI) ---
# 可留空:首启向导 / 管理后台里填,加密存数据库(推荐)。也可在此用 env 提供。
OPENAI_API_KEY=
OPENAI_IMAGE_MODEL=

# --- Storage ---
# 默认本地磁盘(MEDIA_DIR,docker 卷 /data/media),零配置可用。
# 配齐 R2_*(Cloudflare R2,S3 兼容)则自动切换对象存储。
MEDIA_DIR=./data/media
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_BASE_URL=

# --- Auth (Supabase Auth, 可选) ---
# 三个都填启用真实多用户登录(多用户注册为 Pro 能力);留空为单机模式。
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# 管理员邮箱(该 Supabase 用户可见 /admin 管理后台)
ADMIN_EMAIL=

# --- Edition / Pro license ---
# 开源版留空即可。购买 Pro 商业授权后:
#   NOVARYNS_EDITION=pro + PRO_LICENSE_KEY=NOVA-XXXX-...(或在首启向导里填 Key)
NOVARYNS_EDITION=
PRO_LICENSE_KEY=
# License 校验服务器(默认官方,不用改)
LICENSE_SERVER_URL=

# --- Branding (可选,build 期内联;运行时品牌请用后台「品牌与白标」) ---
NEXT_PUBLIC_BRAND_NAME=
NEXT_PUBLIC_BRAND_LOGO=
NEXT_PUBLIC_BRAND_EMAIL=
